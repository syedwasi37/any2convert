# Copy this file to .env and fill in only the keys you need.

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# AI image generator
AI_IMAGE_PROVIDER=pollinations
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=zimage

# Groq is supported elsewhere in the app only if you build features against
# their OpenAI-compatible text/vision endpoints. They do not currently offer
# an official text-to-image endpoint for this tool.
GROQ_API_KEY=
